<script>
// Never render the stored API key into the page (View-Source / DOM / form-cache
// would leak it). The field ships empty; if left blank on Apply, drop its name
// so it isn't POSTed and update.php preserves the existing key (it merges the
// POST over the on-disk cfg). A typed value overwrites as normal.
function pwKeepKey() {
  var k = document.getElementById('pushward_api_key');
  if (k && k.value === '') k.removeAttribute('name');
  return true;
}
</script>

