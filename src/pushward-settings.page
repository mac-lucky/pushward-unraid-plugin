<script>
// Unraid renders the settings form as a centered field column with a wide empty
// left margin. Snap the hero/status/callout/log bands to that same column (left
// edge and width) at runtime so the page reads as one stack. Measured from the
// form's own <dl> (or its fields) so it tracks the active theme and viewport
// instead of a hard-coded guess; falls back to the CSS max-width if JS is off.
(function () {
  var wraps = document.querySelectorAll('.pw-wrap');
  if (!wraps.length) return;
  function fieldBox() {
    var form = document.querySelector('form[name="pushward_unraid_settings"]');
    if (!form) return null;
    var dl = form.querySelector('dl');
    if (dl) { var r = dl.getBoundingClientRect(); if (r.width > 1) return r; }
    var lo = Infinity, hi = -Infinity;
    form.querySelectorAll('input,select,dt,dd,button').forEach(function (e) {
      var b = e.getBoundingClientRect();
      if (b.width > 0) { lo = Math.min(lo, b.left); hi = Math.max(hi, b.right); }
    });
    return isFinite(lo) ? { left: lo, width: hi - lo } : null;
  }
  function align() {
    var box = fieldBox();
    if (!box) return;
    // Reset to baseline width, then read every band's left, then write every
    // margin: batching reads before writes avoids a reflow per band.
    wraps.forEach(function (w) { w.style.marginLeft = '0'; w.style.marginRight = '0'; w.style.maxWidth = Math.round(box.width) + 'px'; });
    var shifts = [];
    wraps.forEach(function (w) { shifts.push(Math.round(box.left - w.getBoundingClientRect().left)); });
    wraps.forEach(function (w, i) { w.style.marginLeft = shifts[i] + 'px'; });
  }
  var pending = 0;
  function schedule() { if (!pending) pending = requestAnimationFrame(function () { pending = 0; align(); }); }
  align();
  setTimeout(align, 300); // re-run after late theme/font layout settles
  window.addEventListener('resize', schedule);
})();
</script>
