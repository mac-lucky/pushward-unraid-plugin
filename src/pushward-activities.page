$plugin   = "pushward-unraid";
$cfg_path = "/boot/config/plugins/{$plugin}/{$plugin}.cfg";
$cfg      = file_exists($cfg_path) ? @parse_ini_file($cfg_path) : [];
$configured = !empty($cfg['PUSHWARD_API_KEY']);
$csrf = '';
if (preg_match('/^csrf_token="?([^"\n]*)"?/m', (string) @file_get_contents('/var/local/emhttp/var.ini'), $m)) {
    $csrf = $m[1];
}
?>

<style>
.pw-wrap {
  --pw-blue:#4a90d9; --pw-green:#5b9b5b; --pw-orange:#b5651d; --pw-red:#c0392b; --pw-indigo:#5b5bd6;
  --pw-blue-bg:rgba(74,144,217,.13); --pw-green-bg:rgba(91,155,91,.13); --pw-orange-bg:rgba(181,101,29,.14);
  --pw-red-bg:rgba(192,57,43,.13); --pw-indigo-bg:rgba(91,91,214,.13);
  --pw-accent:var(--pw-blue); --pw-accent-bg:var(--pw-blue-bg);
  max-width: 880px;
}
.pw-accent-blue   { --pw-accent:var(--pw-blue);   --pw-accent-bg:var(--pw-blue-bg); }
.pw-accent-green  { --pw-accent:var(--pw-green);  --pw-accent-bg:var(--pw-green-bg); }
.pw-accent-orange { --pw-accent:var(--pw-orange); --pw-accent-bg:var(--pw-orange-bg); }
.pw-accent-red    { --pw-accent:var(--pw-red);    --pw-accent-bg:var(--pw-red-bg); }
.pw-accent-indigo { --pw-accent:var(--pw-indigo); --pw-accent-bg:var(--pw-indigo-bg); }
.pw-hero { display:flex; align-items:center; gap:10px; padding:4px 0 12px; margin-bottom:14px; border-bottom:1px solid var(--border-color,rgba(128,128,128,.3)); }
.pw-hero img { height:30px; width:30px; border-radius:7px; display:block; }
.pw-hero .pw-brand { font-weight:700; font-size:1.15em; letter-spacing:.2px; }
.pw-hero .pw-tag { opacity:.55; font-size:.85em; }
.pw-hero .pw-link { margin-left:auto; font-size:.85em; opacity:.8; text-decoration:none; white-space:nowrap; }
.pw-hero .pw-link:hover { opacity:1; text-decoration:underline; }

.pw-card { display:flex; gap:12px; align-items:flex-start; border:1px solid var(--border-color,rgba(128,128,128,.35)); border-left:4px solid var(--pw-accent); border-radius:10px; padding:13px 15px; margin:11px 0; background:var(--pw-accent-bg); box-shadow:0 1px 3px rgba(0,0,0,.10); transition:box-shadow .15s ease, transform .15s ease; }
.pw-card:hover { box-shadow:0 4px 12px rgba(0,0,0,.16); transform:translateY(-1px); }
.pw-icon { flex:0 0 auto; width:36px; height:36px; border-radius:9px; display:flex; align-items:center; justify-content:center; color:var(--pw-accent); background:var(--pw-accent-bg); border:1px solid var(--pw-accent); }
.pw-icon svg { width:20px; height:20px; display:block; }
.pw-body { flex:1 1 auto; min-width:0; }
.pw-head { display:flex; align-items:center; gap:7px; flex-wrap:wrap; }
.pw-name { font-weight:700; font-size:1.05em; }
.pw-badge { font-size:.72em; padding:2px 9px; border-radius:999px; border:1px solid transparent; line-height:1.5; white-space:nowrap; }
.pw-badge-template { color:var(--pw-accent); background:var(--pw-accent-bg); border-color:var(--pw-accent); opacity:.85; }
.pw-badge-state { display:inline-flex; align-items:center; gap:5px; font-weight:600; }
.pw-dot { width:7px; height:7px; border-radius:50%; background:currentColor; display:inline-block; }
.pw-state-ongoing { color:var(--pw-blue); background:var(--pw-blue-bg); border-color:var(--pw-blue); }
.pw-state-ongoing .pw-dot { animation:pw-pulse 1.4s ease-in-out infinite; }
.pw-state-ended { color:var(--pw-green); background:var(--pw-green-bg); border-color:var(--pw-green); }
.pw-state-preempted { color:var(--pw-orange); background:var(--pw-orange-bg); border-color:var(--pw-orange); }
@keyframes pw-pulse { 0%,100%{opacity:1;transform:scale(1);} 50%{opacity:.3;transform:scale(.65);} }

.pw-state-text { margin-top:4px; }
.pw-sub { opacity:.72; font-size:.88em; margin-top:2px; }

.pw-progress { display:flex; align-items:center; gap:9px; margin:9px 0 4px; }
.pw-bar { flex:1 1 auto; height:9px; border-radius:5px; background:rgba(128,128,128,.22); overflow:hidden; }
.pw-bar > span { display:block; height:100%; border-radius:5px; background:var(--pw-accent); background-image:linear-gradient(rgba(255,255,255,.22),rgba(255,255,255,0)); transition:width .4s ease; }
.pw-pct { flex:0 0 auto; font-size:.8em; font-variant-numeric:tabular-nums; opacity:.8; min-width:34px; text-align:right; }
.pw-bar-indeterminate > span { width:35%; background-image:none; transition:none; animation:pw-indet 1.3s ease-in-out infinite; }
@keyframes pw-indet { 0%{transform:translateX(-130%);} 100%{transform:translateX(330%);} }

.pw-lines { font-family:var(--font-mono,monospace); font-size:.8em; line-height:1.5; margin-top:8px; max-height:140px; overflow:auto; background:rgba(128,128,128,.10); border:1px solid var(--border-color,rgba(128,128,128,.25)); border-radius:7px; padding:7px 9px; }
.pw-lines div { padding:1px 0; white-space:pre-wrap; word-break:break-word; }
.pw-lvl-warn { color:var(--pw-orange); }
.pw-lvl-error { color:var(--pw-red); font-weight:600; }

.pw-meta { opacity:.55; font-size:.8em; margin-top:7px; }
.pw-actions { margin-top:10px; display:flex; gap:8px; }
.pw-btn { cursor:pointer; font:inherit; font-size:.82em; padding:5px 13px; border-radius:999px; border:1px solid var(--border-color,#888); background:transparent; color:inherit; transition:background .12s ease, border-color .12s ease; }
.pw-btn:hover { background:rgba(128,128,128,.15); }
.pw-btn-danger { color:var(--pw-red); border-color:var(--pw-red); }
.pw-btn-danger:hover { background:var(--pw-red-bg); }

.pw-empty { text-align:center; opacity:.75; padding:34px 16px; }
.pw-empty svg { width:42px; height:42px; opacity:.5; margin-bottom:8px; }
.pw-empty p { margin:0; }

.pw-warn { color:var(--pw-orange); font-weight:bold; }
.pw-foot { display:flex; align-items:center; gap:7px; opacity:.6; font-size:.82em; margin-top:14px; }
.pw-foot .pw-livedot { width:7px; height:7px; border-radius:50%; background:var(--pw-green); animation:pw-pulse 1.4s ease-in-out infinite; }

@media (max-width:600px) {
  .pw-card { flex-direction:column; gap:8px; }
}
</style>

<div class="pw-wrap">
<div class="pw-hero">
  <img src="/plugins/pushward-unraid/pushward.png" alt="PushWard">
  <span class="pw-brand">PushWard</span><span class="pw-tag">Live Activities</span>
  <a class="pw-link" href="https://pushward.app" target="_blank" rel="noopener noreferrer">pushward.app &rarr;</a>
</div>
<?PHP if (!$configured): ?>
<p class="pw-warn">No API key configured. Set one on <a href="/Settings/pushward-settings">the Settings tab</a> first.</p>
<?PHP else: ?>
<div id="pw-activities"><p class="pw-empty">Loading current Live Activities&hellip;</p></div>
<div id="pw-msg" class="pw-warn" role="alert"></div>
<div class="pw-foot"><span class="pw-livedot"></span>Auto-refreshing every 5s &middot; <span id="pw-updated"></span></div>
<?PHP endif; ?>
</div>

<?PHP if ($configured): ?>
<script>
(function () {
  var API = '/plugins/pushward-unraid/pwapi.php';
  var CSRF = '<?= htmlspecialchars($csrf, ENT_QUOTES) ?>';
  var box = document.getElementById('pw-activities');
  var upd = document.getElementById('pw-updated');
  var msgEl = document.getElementById('pw-msg');
  var msgTimer = null;

  // Inline SVGs are static markup we control (never user data), so they are
  // concatenated raw.
  var SVG = {
    drive: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2"/><circle cx="16.5" cy="12" r="1.6"/><line x1="6" y1="12" x2="12" y2="12"/></svg>',
    backup: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="4" rx="1"/><path d="M5 8v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8"/><line x1="10" y1="12" x2="14" y2="12"/></svg>',
    mover: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="3" x2="12" y2="14"/><polyline points="7 10 12 15 17 10"/><line x1="5" y1="20" x2="19" y2="20"/></svg>',
    vm: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="12" rx="2"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="16" x2="12" y2="20"/></svg>',
    ups: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="17" height="10" rx="2"/><line x1="22" y1="10.5" x2="22" y2="13.5"/><path d="M11.5 9l-2.5 4H11l-.6 2.6L14 11h-2.3z" fill="currentColor" stroke="none"/></svg>',
    activity: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h4l3 8 4-16 3 8h4"/></svg>'
  };

  function iconFor(slug) {
    var s = String(slug || '').toLowerCase();
    var key = 'activity';
    if (s.indexOf('array') >= 0 || s.indexOf('parity') >= 0) key = 'drive';
    else if (s.indexOf('vmbackup') >= 0) key = 'vm';
    else if (s.indexOf('backup') >= 0) key = 'backup';
    else if (s.indexOf('mover') >= 0) key = 'mover';
    else if (s.indexOf('ups') >= 0) key = 'ups';
    return SVG[key];
  }

  // Map the server accent to a whitelisted CSS class (defined in the <style>
  // palette); emit only the fixed class name, never the raw accent string.
  var ACCENT = { blue: 1, green: 1, orange: 1, red: 1, indigo: 1 };
  function accentClass(c) {
    c = String(c || '').toLowerCase();
    return 'pw-accent-' + (ACCENT[c] ? c : 'blue');
  }

  // textContent so a server error string can never inject markup.
  function showMsg(s) {
    if (!msgEl) return;
    msgEl.textContent = s || '';
    if (msgTimer) clearTimeout(msgTimer);
    if (s) msgTimer = setTimeout(function () { msgEl.textContent = ''; }, 8000);
  }

  function errText(d, status) {
    if (d && (d.error || d.detail || d.title)) return d.error || d.detail || d.title;
    return 'HTTP ' + status;
  }

  function esc(s) {
    var d = document.createElement('div');
    d.textContent = (s == null ? '' : String(s));
    // textContent->innerHTML escapes < > &; also escape quotes so the result is
    // safe inside HTML attributes too.
    return d.innerHTML.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function rel(ts) {
    if (!ts) return '';
    var t = (typeof ts === 'string') ? Date.parse(ts) : ts * 1000;
    if (isNaN(t)) return '';
    var s = Math.max(0, Math.round((Date.now() - t) / 1000));
    if (s < 60) return s + 's ago';
    if (s < 3600) return Math.round(s / 60) + 'm ago';
    return Math.round(s / 3600) + 'h ago';
  }

  // `?? 9` not `|| 9`: ongoing ranks 0, which is falsy, so `|| 9` would push live
  // activities to the BOTTOM, the inverse of the intended "active first".
  var RANK = { ongoing: 0, preempted: 1, ended: 2 };
  function order(a, b) {
    return (RANK[a.state] ?? 9) - (RANK[b.state] ?? 9);
  }

  function render(items) {
    if (!items.length) {
      box.innerHTML = '<div class="pw-empty">' + SVG.activity +
        '<p>No Live Activities right now.</p>' +
        '<p class="pw-sub">They appear here while a parity check, appdata backup, mover, VM backup or UPS event runs.</p></div>';
      return;
    }
    items.sort(order);
    var html = '';
    items.forEach(function (a) {
      var c = a.content || {};
      var prog = (typeof c.progress === 'number') ? Math.round(c.progress * 100) : null;
      var ongoing = (a.state === 'ongoing' || a.state === 'preempted');
      html += '<div class="pw-card ' + accentClass(c.accent_color) + '">';
      html += '<div class="pw-icon">' + iconFor(a.slug) + '</div>';
      html += '<div class="pw-body">';
      html += '<div class="pw-head">';
      html += '<span class="pw-name">' + esc(a.name || a.slug) + '</span>';
      if (c.template) html += '<span class="pw-badge pw-badge-template">' + esc(c.template) + '</span>';
      html += '<span class="pw-badge pw-badge-state pw-state-' + esc(a.state) + '"><span class="pw-dot"></span>' + esc(a.state) + '</span>';
      html += '</div>';
      if (c.state) html += '<div class="pw-state-text">' + esc(c.state) + '</div>';
      if (c.subtitle) html += '<div class="pw-sub">' + esc(c.subtitle) + '</div>';
      if (prog !== null) {
        html += '<div class="pw-progress"><div class="pw-bar"><span style="width:' + prog + '%"></span></div><span class="pw-pct">' + prog + '%</span></div>';
      } else if (ongoing) {
        // No percentage (e.g. mover without byte totals): show an indeterminate bar.
        html += '<div class="pw-progress"><div class="pw-bar pw-bar-indeterminate"><span></span></div></div>';
      }
      if (Array.isArray(c.lines) && c.lines.length) {
        html += '<div class="pw-lines">';
        c.lines.forEach(function (ln) { html += '<div class="pw-lvl-' + esc(ln.level || 'info') + '">' + esc(ln.text) + '</div>'; });
        html += '</div>';
      }
      html += '<div class="pw-meta">slug ' + esc(a.slug) + ' &middot; ' + rel(a.updated_at) + '</div>';
      if (ongoing) {
        html += '<div class="pw-actions">';
        html += '<button class="pw-btn" data-act="end" data-slug="' + esc(a.slug) + '">End</button>';
        html += '<button class="pw-btn pw-btn-danger" data-act="cancel" data-slug="' + esc(a.slug) + '">Cancel (delete)</button>';
        html += '</div>';
      }
      html += '</div></div>';
    });
    box.innerHTML = html;
  }

  function pwAct(action, slug) {
    if (action === 'cancel' && !confirm('Delete activity "' + slug + '"? This removes it for all your devices.')) return;
    var body = 'action=' + encodeURIComponent(action) + '&slug=' + encodeURIComponent(slug) + '&csrf_token=' + encodeURIComponent(CSRF);
    fetch(API, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body })
      .then(function (r) {
        return r.text().then(function (t) {
          // Surface failures (403 missing/rotated CSRF or scope, 404, 5xx)
          // instead of silently reloading so the action looks like a no-op.
          if (!r.ok) {
            var d = {}; try { d = JSON.parse(t); } catch (e) {}
            showMsg((action === 'cancel' ? 'Cancel' : 'End') + ' failed: ' + errText(d, r.status));
          } else {
            showMsg('');
          }
          load();
        });
      })
      .catch(function () { showMsg('Request failed: could not reach the plugin proxy.'); load(); });
  }

  // Delegated handler (no inline onclick) so a quote in a slug can't inject.
  box.addEventListener('click', function (e) {
    var btn = e.target.closest && e.target.closest('button[data-act]');
    if (btn) pwAct(btn.getAttribute('data-act'), btn.getAttribute('data-slug'));
  });

  var lastBody = null;
  function load() {
    fetch(API + '?action=list', { headers: { 'Accept': 'application/json' } })
      .then(function (r) {
        return r.text().then(function (t) {
          var d = {}; try { d = JSON.parse(t); } catch (e) {}
          // Don't let a 401/expired-key or proxy 502 fall through to an empty
          // list, which renders a reassuring "nothing running" during an actual
          // outage. Show the error instead.
          if (!r.ok) {
            lastBody = null;
            box.innerHTML = '<p class="pw-warn">PushWard API error: ' + esc(errText(d, r.status)) +
              '. Check the key and server URL on the Settings tab.</p>';
            if (upd) upd.textContent = 'error ' + new Date().toLocaleTimeString();
            return;
          }
          if (upd) upd.textContent = 'updated ' + new Date().toLocaleTimeString();
          // Re-render only when the payload changed: rebuilding innerHTML every
          // poll would restart the live-dot/indeterminate animations and reset
          // the log scroll position.
          if (t === lastBody) return;
          lastBody = t;
          render(d.items || d.activities || d.data || []);
        });
      })
      .catch(function () {
        lastBody = null;
        box.innerHTML = '<p class="pw-warn">Could not reach the PushWard API. Check the key and server URL on the Settings tab.</p>';
      });
  }

  load();
  // Poll while the tab is visible only, and refresh immediately on return, so a
  // backgrounded tab stops hitting the API.
  setInterval(function () { if (!document.hidden) load(); }, 5000);
  document.addEventListener('visibilitychange', function () { if (!document.hidden) load(); });
})();
</script>
<?PHP endif; ?>
